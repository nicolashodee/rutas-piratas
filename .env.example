# =========================================================
# Côté client (exposé au navigateur via Vite) — préfixe VITE_
# =========================================================
VITE_SUPABASE_URL=https://xxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...         # clé publique, OK dans le bundle

# =========================================================
# Côté serveur (Netlify Functions) — JAMAIS préfixer VITE_
# À configurer dans Netlify → Site settings → Environment variables
# =========================================================
SUPABASE_URL=https://xxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...       # secret absolu, bypass RLS

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# URL publique de l'app (pour les redirections Stripe success/cancel)
PUBLIC_SITE_URL=https://app.rutas-piratas.fr
